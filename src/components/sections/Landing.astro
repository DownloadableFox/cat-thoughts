---
import Icon from "../ui/Icon.astro";
import WhoAmI from "../ui/WhoAmI.astro";
import Socials from "../ui/Socials.astro";
import BuiltWith from "../ui/BuiltWith.astro";
import ContentArrow from "../ui/ContentArrow.astro";
---

<div
    id="landing"
    class="relative w-full min-h-screen flex flex-col items-center justify-center gap-16 px-8 py-16"
>
    <div
        class="flex flex-wrap items-center justify-center max-w-6xl w-full gap-16 lg:gap-32"
    >
        <Icon />
        <div class="max-w-min grow flex flex-col items-start justify-center">
            <WhoAmI />
        </div>
    </div>
    <div class="w-full flex justify-center">
        <Socials />
    </div>

    <BuiltWith />
    <ContentArrow />
</div>
