---
import Favicon from  "../../assets/svgs/favicon.svg";

const totally_normal_video = "https://www.youtube.com/watch?v=dQw4w9WgXcQ";
---

<nav
    class="fixed z-50 top-0 left-0 w-full flex flex-row items-center justify-between py-4 px-8 gap-6"
>
    <a
        href="#landing"
        aria-label="Home"
        class="bg-text rounded-full hover:bg-primary transition-all"
    >
        <Favicon
            id="favicon"
            class="h-6 w-6 m-1 aspect-square transition-all hidden"
        />
    </a>

    <div class="flex flex-row items-center gap-6">
        <a
            href="#about-me"
            class="text-xl font-mono tracking-tight text-text hover:text-primary transition-all">About</a
        >
        <a
            href={totally_normal_video}
            class="text-xl font-mono tracking-tight text-text hover:text-primary transition-all">Projects</a
        >
        <a
            href={totally_normal_video}
            class="text-xl font-mono tracking-tight text-text hover:text-primary transition-all">Blog</a
        >
    </div>
</nav>


<script>
    const favicon = document.getElementById("favicon");

    const handleScroll = () => {
        if (window.scrollY >= window.innerHeight) {
            favicon?.classList.remove("hidden");
        } else {
            favicon?.classList.add("hidden");
        }
    };

    window.addEventListener("scroll", handleScroll);
</script>
